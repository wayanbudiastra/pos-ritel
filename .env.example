# Salin file ini ke .env (lokal) dan isi juga sebagai Environment Variables
# di Vercel Project Settings sebelum deploy.

# Neon Postgres — gunakan connection string pooled untuk runtime query,
# dan direct (tanpa "-pooler") untuk migration (DIRECT_URL).
DATABASE_URL='postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require'
DIRECT_URL='postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require'

# NextAuth/Auth.js — generate dengan: openssl rand -base64 32
AUTH_SECRET='replace-with-openssl-rand-base64-32'

# Opsional: melindungi endpoint /api/cron/aggregate-daily dari pemanggilan
# luar. Jika diisi, Vercel Cron otomatis mengirim header
# "Authorization: Bearer <CRON_SECRET>" ke endpoint cron.
CRON_SECRET=''
